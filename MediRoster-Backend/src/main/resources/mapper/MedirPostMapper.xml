<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediroster.mapper.MedirPostMapper">

    <resultMap id="BaseResultMap" type="com.mediroster.entity.MedirPost">
        <id column="id" property="id"/>
        <result column="post_code" property="postCode"/>
        <result column="post_name" property="postName"/>
        <result column="description" property="description"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO medir_post (post_code, post_name, description, sort_order, enabled)
        VALUES (#{postCode}, #{postName}, #{description}, #{sortOrder}, #{enabled})
    </insert>

    <update id="updateById">
        UPDATE medir_post
        SET post_code = #{postCode},
            post_name = #{postName},
            description = #{description},
            sort_order = #{sortOrder},
            enabled = #{enabled}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM medir_post WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM medir_post WHERE id = #{id}
    </select>

    <select id="findByPostCode" resultMap="BaseResultMap">
        SELECT * FROM medir_post WHERE post_code = #{postCode}
    </select>

    <select id="findAll" resultMap="BaseResultMap">
        SELECT * FROM medir_post ORDER BY sort_order, id
    </select>
</mapper>
