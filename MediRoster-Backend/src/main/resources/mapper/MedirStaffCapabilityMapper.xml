<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediroster.mapper.MedirStaffCapabilityMapper">

    <resultMap id="BaseResultMap" type="com.mediroster.entity.MedirStaffCapability">
        <id column="id" property="id"/>
        <result column="staff_id" property="staffId"/>
        <result column="capability_code" property="capabilityCode"/>
        <result column="enabled" property="enabled"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO medir_staff_capability (staff_id, capability_code, enabled)
        VALUES (#{staffId}, #{capabilityCode}, #{enabled})
    </insert>

    <delete id="deleteById">
        DELETE FROM medir_staff_capability WHERE id = #{id}
    </delete>

    <delete id="deleteByStaffAndCode">
        DELETE FROM medir_staff_capability WHERE staff_id = #{staffId} AND capability_code = #{capabilityCode}
    </delete>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM medir_staff_capability WHERE id = #{id}
    </select>

    <select id="findByStaffId" resultMap="BaseResultMap">
        SELECT * FROM medir_staff_capability WHERE staff_id = #{staffId} ORDER BY id
    </select>
</mapper>
