<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.mediroster.mapper.MedirCalendarDayMapper">

    <resultMap id="BaseResultMap" type="com.mediroster.entity.MedirCalendarDay">
        <id column="id" property="id"/>
        <result column="cal_date" property="calDate"/>
        <result column="day_type" property="dayType"/>
        <result column="holiday_name" property="holidayName"/>
        <result column="created_at" property="createdAt"/>
        <result column="updated_at" property="updatedAt"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO medir_calendar_day (cal_date, day_type, holiday_name)
        VALUES (#{calDate}, #{dayType}, #{holidayName})
    </insert>

    <update id="updateById">
        UPDATE medir_calendar_day SET
            cal_date = #{calDate},
            day_type = #{dayType},
            holiday_name = #{holidayName}
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM medir_calendar_day WHERE id = #{id}
    </delete>

    <select id="findById" resultMap="BaseResultMap">
        SELECT * FROM medir_calendar_day WHERE id = #{id}
    </select>

    <select id="findByCalDate" resultMap="BaseResultMap">
        SELECT * FROM medir_calendar_day WHERE cal_date = #{calDate}
    </select>

    <select id="findByRange" resultMap="BaseResultMap">
        SELECT * FROM medir_calendar_day WHERE cal_date BETWEEN #{from} AND #{to} ORDER BY cal_date
    </select>
</mapper>
